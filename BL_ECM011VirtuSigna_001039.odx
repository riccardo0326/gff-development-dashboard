                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-SHARED-DATAS/ECU-SHARED-DATA[@ID='BL_ECM011VirtuSigna']/DIAG-DATA-DICTIONARY-SPEC/TABLES/TABLE[@ID='TAB_RecorDataIdentMeasuValue']/TABLE-ROW[@ID='TAB_RecorDataIdentMeasuValue.TABROW_CamshPositDiagnOveraEnabe']/DESC", "-", "&lt;p&gt;Gemeinsame Freigabebedingung während Start für alle verstellten Nockenwellen&lt;/p&gt;")</CHANGE>
                </MODIFICATION>
                <MODIFICATION>
                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-SHARED-DATAS/ECU-SHARED-DATA[@ID='BL_ECM011VirtuSigna']/DIAG-DATA-DICTIONARY-SPEC/TABLES/TABLE[@ID='TAB_RecorDataIdentMeasuValue']/TABLE-ROW[@ID='TAB_RecorDataIdentMeasuValue.TABROW_CondiForBasicAdjus']/DESC", "-", "&lt;p&gt;
  &lt;ul&gt;
    &lt;li&gt;Bit 0 Kühlmitteltemperatur größer 80°C Bed. N. erf. Bed. Erfüllt&lt;/li&gt;
    &lt;li&gt;Bit 1 Drehzahl kleiner 2000 1/min Bed. N. erf. Bed. Erf.&lt;/li&gt;
    &lt;li&gt;Bit 2 Drosselklappe zu Bed. N. erf. Bed. Erf.&lt;/li&gt;
    &lt;li&gt;Bit 3 Lambdaregelung: i.O. Bed. N. erf. Bed. Erf.&lt;/li&gt;
    &lt;li&gt;Bit 4 Leerlaufschalter zu Bed. N. erf. Bed. Erf.&lt;/li&gt;
    &lt;li&gt;Bit 5 Klimakompressor aus Bed. N. erf. Bed. Erf.&lt;/li&gt;
    &lt;li&gt;Bit 6 Kat-Temp. Erreicht Bed. N. erf. Bed. Erf.&lt;/li&gt;
    &lt;li&gt;Bit 7 kein Fehler Im Fehlerspeicher Bed. N. erf. Bed. Erf.&lt;/li&gt;
  &lt;/ul&gt;
&lt;/p&gt;")</CHANGE>
