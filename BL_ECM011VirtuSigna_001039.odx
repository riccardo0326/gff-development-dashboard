                </MODIFICATION>
                <MODIFICATION>
                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-SHARED-DATAS/ECU-SHARED-DATA[@ID='BL_ECM011VirtuSigna']/DIAG-DATA-DICTIONARY-SPEC/TABLES/TABLE[@ID='TAB_RecorDataIdentMeasuValue']/TABLE-ROW[@ID='TAB_RecorDataIdentMeasuValue.TABROW_StateAdaptEndDewPoint']/DESC", "-", "&lt;p&gt;
  &lt;ul&gt;
    &lt;li&gt;1: Test ein&lt;/li&gt;
    &lt;li&gt;2: Test aus&lt;/li&gt;
    &lt;li&gt;3: i.O.&lt;/li&gt;
    &lt;li&gt;4: nicht i.O.&lt;/li&gt;
  &lt;/ul&gt;
&lt;/p&gt;")</CHANGE>
                </MODIFICATION>
