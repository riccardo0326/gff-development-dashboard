                <MODIFICATION>
                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-SHARED-DATAS/ECU-SHARED-DATA[@ID='BL_ECM011VirtuSigna']/DIAG-DATA-DICTIONARY-SPEC/TABLES/TABLE[@ID='TAB_RecorDataIdentMeasuValue']/TABLE-ROW[@ID='TAB_RecorDataIdentMeasuValue.TABROW_ResulAgingTestOxygeSensoBank1BeforCatalConve']/DESC", "-", "&lt;p&gt;LSF vor Kat: Anzeige ob Lambda-Offset-Überwachung für Lambda Sonde vor Kat iO istLSU vor Kat: Anzeige ob Lambdasonde vor Kat iO ist (wenn LSU vor Kat verbaut)&lt;/p&gt;")</CHANGE>
                </MODIFICATION>
                <MODIFICATION>
                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-SHARED-DATAS/ECU-SHARED-DATA[@ID='BL_ECM011VirtuSigna']/DIAG-DATA-DICTIONARY-SPEC/TABLES/TABLE[@ID='TAB_RecorDataIdentMeasuValue']/TABLE-ROW[@ID='TAB_RecorDataIdentMeasuValue.TABROW_ResulOxygeSensoAgingBank13BeforCat']/KEY", "Result oxygen sensor aging Bank 1 / 3 before Cat", "result oxygen sensor aging Bank 1 / 3 before Cat")</CHANGE>
                </MODIFICATION>
                <MODIFICATION>
                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-SHARED-DATAS/ECU-SHARED-DATA[@ID='BL_ECM011VirtuSigna']/DIAG-DATA-DICTIONARY-SPEC/TABLES/TABLE[@ID='TAB_RecorDataIdentMeasuValue']/TABLE-ROW[@ID='TAB_RecorDataIdentMeasuValue.TABROW_SCRInducResetState']/DESC", "-", "&lt;p&gt;Um das SCR-Inducement rückzusetzen, müssen bei einem Systemfehler alle Fehlerpfade, die sich in der Fehlergruppe befinden, die den Systemfehler verursacht haben, ein iO-Test-Ergebnis zurückmelden.
Nach einer erfolgten Reparatur und einem Fehlerspeicher löschen, ist das Inducement nicht gelöscht! 
Die Werkstatt muss erst eine unter Umständen sehr lange Probefahrt durchführen, um alle Diagnosen iO abzuprüfen. Ein Messwert soll helfen, nur die Diagnosen anzuzeigen, die benötigt werden, um das Inducement zurückzusetzen.
Alle Diagnosen, die in dem Messwert angezeigt werden, benötigen noch ein iO-Test-Ergebnis.
Anhand des DFCCs kann der Kundendienst in den SDG-Beschreibung der EV.odx die Freigabebedingung der Diagnose ablesen und diese gezielt zum iO-Test-Ergebnis „fahren“.
Der Messwert ist zur Erstellung der GFS erforderlich und soll in der Werkstatt nicht beachtet werden.&lt;/p&gt;")</CHANGE>
                </MODIFICATION>
                <MODIFICATION>
                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-SHARED-DATAS/ECU-SHARED-DATA[@ID='BL_ECM011VirtuSigna']/DIAG-DATA-DICTIONARY-SPEC/TABLES/TABLE[@ID='TAB_RecorDataIdentMeasuValue']/TABLE-ROW[@ID='TAB_RecorDataIdentMeasuValue.TABROW_SnapsA']/DESC", "-", "&lt;p&gt;Entwicklermesswert für WFS
soll ab UDS  im  AdditionalFreezeFrame mit ausgegeben werden&lt;/p&gt;")</CHANGE>
                </MODIFICATION>
                <MODIFICATION>
                  <CHANGE>@@changed("Sonst", "-", "-", "/ODX/DIAG-LAYER-CONTAINER/ECU-SHARED-DATAS/ECU-SHARED-DATA[@ID='BL_ECM011VirtuSigna']/DIAG-DATA-DICTIONARY-SPEC/TABLES/TABLE[@ID='TAB_RecorDataIdentMeasuValue']/TABLE-ROW[@ID='TAB_RecorDataIdentMeasuValue.TABROW_SnapsA']/STRUCTURE-REF/@ID-REF", "STRUC_SiaErrorSnapA", "STRUC_SiaErrorSnap")</CHANGE>
