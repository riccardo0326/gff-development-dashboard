        <SHORT-NAME>Param_SupprPositRespoMessaIndicBit</SHORT-NAME>
        <LONG-NAME>Suppress Positive Response Message Indication Bit</LONG-NAME>
        <BYTE-POSITION>1</BYTE-POSITION>
        <BIT-POSITION>7</BIT-POSITION>
